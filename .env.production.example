APP_ENV=production

# Security (REQUIRED for production)
JWT_SECRET_KEY=replace-with-a-long-random-production-secret
ADMIN_INVITE_CODE=replace-with-a-private-admin-invite-code
ALLOWED_ORIGINS=https://your-domain.example
RATE_LIMIT=60/minute
MAX_UPLOAD_SIZE_MB=100

# Database and Redis
DATABASE_URL=postgresql+psycopg2://postgres:change-me@postgres:5432/paperrag
REDIS_URL=redis://redis:6379/0
USE_REDIS_JOB_MANAGER=true

# LLM
LLM_PROVIDER=openai
LLM_API_KEY=replace-with-provider-key
LLM_BASE_URL=
LLM_MODEL=
LLM_GRADE_MODEL=gpt-4.1

# Vector database
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION=embeddings_collection

# Retrieval
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
RERANK_MODEL=
RERANK_BINDING_HOST=
RERANK_API_KEY=
LOCAL_RERANKER=false
