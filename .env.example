# ===== LLM Provider 统一配置（推荐使用） =====
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# LLM_GRADE_MODEL=gpt-4.1
# LLM_API_KEY=sk-
# LLM_BASE_URL=https://api.openai.com/v1

# ===== LLM 旧变量（向后兼容，新项目请使用上方统一配置）=====
ARK_API_KEY= #7a
MODEL= #doubao-seed-2-0-pro-260215
GRADE_MODEL= #doubao-seed-2-0-lite-260215
FAST_MODEL= #doubao-seed-1-6-flash-250828
BASE_URL= #https://ark.cn-beijing.volces.com/api/v3

# 本地密集向量（langchain_huggingface / sentence-transformers）
EMBEDDING_MODEL= #BAAI/bge-m3
EMBEDDING_DEVICE= #cpu
DENSE_EMBEDDING_DIM= #1024
# HF 模型缓存目录（默认项目根下 models/）
# HF_HOME=./models

# ===== JSON 结构化日志（设置 true 后日志输出 JSON 格式，适合 APM 采集）=====
# JSON_LOG=false

# ===== Rerank (可选，不配则自动降级) =====
RERANK_MODEL= #jina-reranker-v3
RERANK_BINDING_HOST= #https://api.jina.ai/v1/rerank
RERANK_API_KEY= #jina_

# ===== Milvus =====
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530

# BM25 稀疏统计持久化（默认项目根下 data/bm25_state.json）
# BM25_STATE_PATH=

# ===== 本地 Reranker（设置 true 后优先使用本地 BGE-Reranker-v2-M3）=====
# LOCAL_RERANKER=false

# ===== 语义缓存 =====
# ENABLE_CACHE=true
# CACHE_MAX_SIZE=500
# CACHE_TTL_SECONDS=604800
# CACHE_SIM_THRESHOLD=0.92

# ===== 文档解析 =====
# 并行解析工作线程数
# PARSE_MAX_WORKERS=4
# 学术论文文本清洗（移除页眉页脚、引用块等）
# ENABLE_ACADEMIC_CLEANING=true
# 基于文档结构的分块（Markdown 标题粗分 + 递归字符切分兜底）
# ENABLE_STRUCTURAL_CHUNKING=true
# 分块参数
# CHUNK_SIZE=800
# CHUNK_OVERLAP=100

# ===== 上下文扩展 =====
# ENABLE_CONTEXT_EXPANSION=true
# EXPAND_PREV_PARENT=1
# EXPAND_NEXT_PARENT=1
# EXPAND_MAX_TOTAL_CHUNKS=30

# ===== CORS（生产环境必须限制来源）=====
# ALLOWED_ORIGINS=http://localhost:5173,https://your-domain.com

# ===== 数据库连接池 =====
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20

# ===== 任务管理器（Redis 模式支持多 worker / 重启恢复）=====
# USE_REDIS_JOB_MANAGER=false

# ===== 认证 =====
# JWT_SECRET_KEY=replace-with-strong-random-secret
# JWT_EXPIRE_MINUTES=1440
# ADMIN_INVITE_CODE=paperrag-admin-2026

# ===== Agent Configuration =====
# Agent enabled (uses citelocal-agent architecture)
# AGENT_ENABLED=true

# Entailment backend for citation verification
# Options: nli | llm | off
# ENTAILMENT_BACKEND=nli